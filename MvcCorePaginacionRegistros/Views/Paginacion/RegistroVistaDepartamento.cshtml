@model VistaDepartamento

<h1>Paginacion individual</h1>
<hr />
<h3>Registro @Model.Posicion de @ViewBag.Ultimo</h3>
<div>
    <ul>
        <li>
            <a asp-controller="Paginacion" asp-action="RegistroVistaDepartamento" asp-route-posicion="1">Primero</a>
        </li>
        <li>
            <a asp-controller="Paginacion" asp-action="RegistroVistaDepartamento" asp-route-posicion="@ViewBag.Anterior">Anterior</a>
        </li>
        <li>
            <a asp-controller="Paginacion" asp-action="RegistroVistaDepartamento" asp-route-posicion="@ViewBag.Siguiente">Siguiente</a>
        </li>
        <li>
            <a asp-controller="Paginacion" asp-action="RegistroVistaDepartamento" asp-route-posicion="@ViewBag.Ultimo">Ultimo</a>
        </li>
    </ul>
</div>
<hr />
<ul class="list-group">
    <li class="list-group-item">Numero: @Model.IdDepartamento</li>
    <li class="list-group-item">Numero: @Model.Nombre</li>
    <li class="list-group-item">Numero: @Model.Localidad</li>
</ul>